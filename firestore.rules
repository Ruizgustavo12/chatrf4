rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: cada uno puede leer/escribir su propio doc
    // Cualquier usuario autenticado puede actualizar SOLO el campo "notifs" de otro usuario
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Permitir que otros usuarios autenticados agreguen notificaciones
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifs']);
    }

    // Chats: solo los participantes pueden leer/escribir
    match /chats/{chatId}/messages/{msgId} {
      allow read, write: if request.auth != null
        && chatId.split('_').hasAll([request.auth.uid]);
    }

    // Posts: cualquier autenticado puede leer, solo el dueño puede crear/borrar
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // para reacciones y comentarios
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Presencia: cada usuario escribe la suya, todos pueden leer
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Spots, stories, trofeos, etc.
    match /{collection}/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
