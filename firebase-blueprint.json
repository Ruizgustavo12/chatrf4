{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "coverPhoto": { "type": "string" },
        "bio": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "friends": { "type": "array", "items": { "type": "string" } },
        "friendRequests": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "name", "email"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "video": { "type": "string" },
        "ts": { "type": "object" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentCount": { "type": "number" }
      },
      "required": ["uid", "name", "ts"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "text": { "type": "string" },
        "ts": { "type": "object" }
      },
      "required": ["postId", "uid", "name", "text", "ts"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTs": { "type": "number" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "ts": { "type": "number" }
      },
      "required": ["chatId", "senderUid", "ts"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" },
        "fromAvatar": { "type": "string" },
        "read": { "type": "boolean" },
        "ts": { "type": "object" }
      },
      "required": ["type", "fromUid", "ts"]
    },
    "Group": {
      "title": "Group",
      "description": "A social group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "cover": { "type": "string" },
        "adminUid": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "pendingRequests": { "type": "array", "items": { "type": "string" } },
        "privacy": { "type": "string", "enum": ["public", "private"] },
        "ts": { "type": "number" }
      },
      "required": ["name", "adminUid", "privacy"]
    },
    "MarketplaceListing": {
      "title": "MarketplaceListing",
      "description": "An item for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "location": { "type": "string" },
        "sellerUid": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerAvatar": { "type": "string" },
        "ts": { "type": "number" }
      },
      "required": ["title", "price", "sellerUid"]
    },
    "Story": {
      "title": "Story",
      "description": "A user story",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "ts": { "type": "number" },
        "expiresAt": { "type": "number" }
      },
      "required": ["uid", "name", "ts", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/posts/{postId}": { "schema": "Post", "description": "Public posts" },
    "/posts/{postId}/comments/{commentId}": { "schema": "Comment", "description": "Comments on posts" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat conversations" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat" },
    "/notifications/{userId}/items/{notifId}": { "schema": "Notification", "description": "User notifications" },
    "/groups/{groupId}": { "schema": "Group", "description": "Social groups" },
    "/groups/{groupId}/posts/{postId}": { "schema": "Post", "description": "Posts within a group" },
    "/marketplace/{listingId}": { "schema": "MarketplaceListing", "description": "Marketplace items" },
    "/stories/{userId}/items/{storyId}": { "schema": "Story", "description": "User stories" },
    "/online/{userId}": { "schema": { "type": "object", "properties": { "online": { "type": "boolean" }, "ts": { "type": "number" } } }, "description": "Presence status" }
  }
}
